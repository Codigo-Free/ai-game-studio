          "asset": "star",
          "rate": 0.0,
          "lifetime": 0.7,
          "speed": 260.0,
          "direction": 90.0,
          "spread": 360.0,
          "gravity": -400.0,
          "start_scale": 0.35,
          "end_scale": 0.05,
          "start_opacity": 1.0,
          "end_opacity": 0.0,
          "layer": 6,
          "emitting": false
        }
      }
    }
