  "animations": [
    {
      "name": "star-pulse",
      "fps": 30,
      "loop": false,
      "tracks": [
        {
          "entity": "goal-star",
          "property": "transform2d.scale_x",
          "keyframes": [
            {
              "frame": 0,
              "value": 1.0,
              "easing": "ease_out"
            },
            {
              "frame": 8,
              "value": 1.7,
              "easing": "ease_in"
            },
            {
              "frame": 16,
              "value": 1.0,
              "easing": "linear"
            }
          ]
        },
        {
          "entity": "goal-star",
          "property": "transform2d.scale_y",
          "keyframes": [
            {
              "frame": 0,
              "value": 1.0,
              "easing": "ease_out"
            },
            {
              "frame": 8,
              "value": 1.7,
              "easing": "ease_in"
            },
            {
              "frame": 16,
